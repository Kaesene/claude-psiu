{
  "description": "Psiu plugin — Stop, StopFailure, and Notification hooks for sound/toast/TTS alerts",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/psiu.sh\" stop",
            "shell": "bash",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/psiu.sh\" stop_failure",
            "shell": "bash",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/psiu.sh\" notification",
            "shell": "bash",
            "async": true
          }
        ]
      }
    ]
  }
}
